# ╔══════════════════════════════════════════════════════════════╗
# ║       GlobalSolutions Platform — Backend Config Template     ║
# ║  Copy this file to .env and fill in your values.            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://gs_user:gs_pass@localhost:5432/globalsolutions

# ── Firebase Admin SDK ────────────────────────────────────────
# Path to the service account JSON downloaded from Firebase Console
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Your Firebase project ID (found in Project Settings → General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Realtime Database URL (if using RTDB for live state)
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
