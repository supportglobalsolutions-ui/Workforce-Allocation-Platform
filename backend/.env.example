# ╔══════════════════════════════════════════════════════════════╗
# ║       GlobalSolutions Platform — Backend Config Template     ║
# ║  Copy this file to .env and fill in your values.            ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://gs_user:gs_pass@localhost:5432/globalsolutions

# ── Firebase Admin SDK ────────────────────────────────────────
# Path to service account JSON (repo root admin.json or backend/firebase-service-account.json)
FIREBASE_CREDENTIALS_PATH=../admin.json

# Your Firebase project ID (found in Project Settings → General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Realtime Database URL (if using RTDB for live state)
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ── Uptime Kuma (RDP TCP heartbeat) ─────────────────────────
UPTIME_KUMA_URL=http://localhost:3001
UPTIME_KUMA_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ── Resend (email: payslips, broadcasts, notification emails) ─
# Create an API key at https://resend.com — app does NOT need to be hosted
# on the sending domain; only DNS (SPF/DKIM) must be verified in Resend.
RESEND_API_KEY=
# Must use a domain verified in Resend (e.g. noreply@yourdomain.com)
RESEND_FROM_EMAIL=GlobalSolutions <noreply@gsdeck.com>
